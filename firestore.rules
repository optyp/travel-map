rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, delete: if request.auth != null && request.auth.uid == userId;
      allow create, update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.keys().hasOnly(['schemaVersion', 'state', 'profile', 'updatedAt'])
        && request.resource.data.schemaVersion == 2
        && request.resource.data.state is map
        && (!request.resource.data.keys().hasAny(['profile'])
          || (request.resource.data.profile is map
            && request.resource.data.profile.keys().hasOnly(['nickname'])
            && request.resource.data.profile.nickname is string
            && request.resource.data.profile.nickname.size() <= 30));
    }
  }
}
